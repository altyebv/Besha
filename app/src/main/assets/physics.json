          "summary": "دراسة قوانين نيوتن الثلاثة وتطبيقاتها العملية",
          "sections": [
            {
              "id": "sec_phys_intro",
              "title": "مقدمة في ديناميكا الحركة",
              "order": 1,
              "conceptIds": [
                "concept_phys_newton2",
                "concept_phys_velocity"
              ],
              "blocks": [
                {
                  "id": "blk_phys_text1",
                  "type": "TEXT",
                  "content": "تُعدّ قوانين نيوتن للحركة من أهم الإنجازات العلمية في تاريخ الفيزياء الكلاسيكية. صاغها العالم الإنجليزي إسحاق نيوتن في القرن السابع عشر، وما زالت حتى اليوم الأساس الذي تُبنى عليه الميكانيكا الكلاسيكية وتطبيقاتها الهندسية.",
                  "order": 1,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_phys_heading1",
                  "type": "HEADING",
                  "content": "قانون نيوتن الثاني",
                  "order": 2,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_phys_highlight1",
                  "type": "HIGHLIGHT_BOX",
                  "content": "القانون الثاني: القوة المحصلة على جسم تساوي كتلته مضروبة في تسارعه.\nF = m × a\nحيث: F = القوة (نيوتن)، m = الكتلة (كيلوجرام)، a = التسارع (م/ث²)",
                  "order": 3,
                  "conceptRef": "concept_phys_newton2",
                  "caption": null,
                  "metadata": "{\"style\": \"definition\"}"
                },
                {
                  "id": "blk_phys_formula1",
                  "type": "FORMULA",
                  "content": "F = m \\times a",
                  "order": 4,
                  "conceptRef": "concept_phys_newton2",
                  "caption": "قانون نيوتن الثاني للحركة",
                  "metadata": "{\"displayMode\": true}"
                },
                {
                  "id": "blk_phys_divider1",
                  "type": "DIVIDER",
                  "content": "",
                  "order": 5,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_phys_heading2",
                  "type": "HEADING",
                  "content": "وحدات القياس",
                  "order": 6,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 3}"
                },
                {
                  "id": "blk_phys_table1",
                  "type": "TABLE",
                  "content": "{\"headers\":[\"الكمية\",\"الرمز\",\"الوحدة\"],\"rows\":[{\"cells\":[\"القوة\",\"F\",\"نيوتن (N)\"]},{\"cells\":[\"الكتلة\",\"m\",\"كيلوجرام (kg)\"]},{\"cells\":[\"التسارع\",\"a\",\"م/ث²\"]},{\"cells\":[\"السرعة\",\"v\",\"م/ث\"]}]}",
                  "order": 7,
                  "conceptRef": null,
                  "caption": "وحدات الكميات الفيزيائية الأساسية",
                  "metadata": null
                },
                {
                  "id": "blk_phys_tip1",
                  "type": "TIP",
                  "content": "تذكر: عند حل المسائل، تأكد دائماً من توحيد الوحدات قبل التعويض في المعادلة.",
                  "order": 8,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_phys_example1",
                  "type": "EXAMPLE",
                  "content": "جسم كتلته 5 كيلوجرام يتحرك بتسارع 3 م/ث². احسب القوة المؤثرة عليه.\n\nالحل:\nF = m × a\nF = 5 × 3\nF = 15 نيوتن",
                  "order": 9,
                  "conceptRef": "concept_phys_newton2",
                  "caption": "مثال تطبيقي على القانون الثاني",
                  "metadata": null
                },
                {
                  "id": "blk_phys_list1",
                  "type": "LIST",
                  "content": "قانون القصور الذاتي: الجسم الساكن يبقى ساكناً والمتحرك يبقى متحركاً ما لم تؤثر عليه قوة\nقانون التسارع: القوة المحصلة = الكتلة × التسارع\nقانون التفاعل: لكل فعل رد فعل مساوٍ له في المقدار ومعاكس له في الاتجاه",
                  "order": 10,
                  "conceptRef": null,
                  "caption": "قوانين نيوتن الثلاثة مختصرة",
                  "metadata": "{\"style\": \"numbered\"}"
                },
                {
                  "id": "blk_phys_quote1",
                  "type": "QUOTE",
                  "content": "إذا رأيت أبعد مما رآه غيري، فذلك لأنني وقفت على أكتاف العمالقة.",
                  "order": 11,
                  "conceptRef": null,
                  "caption": "إسحاق نيوتن",
                  "metadata": null
                }
              ]
