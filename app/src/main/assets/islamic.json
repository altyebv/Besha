      "lessons": [
        {
          "id": "lesson_isl_arkaan",
          "title": "أركان الإسلام الخمسة",
          "order": 1,
          "estimatedMinutes": 20,
          "summary": "دراسة أركان الإسلام الخمسة وشروطها وأهميتها",
          "sections": [
            {
              "id": "sec_isl_intro",
              "title": "التوحيد وأركان الإسلام",
              "order": 1,
              "conceptIds": ["concept_isl_tawhid", "concept_isl_arkaan"],
              "blocks": [
                {
                  "id": "blk_isl_text1",
                  "type": "TEXT",
                  "content": "الإسلام دين شامل يُنظّم علاقة الإنسان بربه وبأخيه الإنسان وبالكون من حوله. ويقوم الإسلام على جملة من المبادئ والأركان التي تُشكّل هيكله وأساسه، ويأتي التوحيد في مقدمة هذه المبادئ باعتباره لبّ الرسالة الإسلامية.",
                  "order": 1,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_isl_heading1",
                  "type": "HEADING",
                  "content": "التوحيد: أساس الدين",
                  "order": 2,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_isl_highlight1",
                  "type": "HIGHLIGHT_BOX",
                  "content": "التوحيد: إفراد الله تعالى بالعبادة، وهو ثلاثة أنواع:\n• توحيد الربوبية: الإيمان بأن الله هو الخالق الرازق المدبّر\n• توحيد الألوهية: إفراد الله بالعبادة\n• توحيد الأسماء والصفات: الإيمان بما وصف الله به نفسه",
                  "order": 3,
                  "conceptRef": "concept_isl_tawhid",
                  "caption": null,
                  "metadata": "{\"style\": \"definition\"}"
                },
                {
                  "id": "blk_isl_quote1",
                  "type": "QUOTE",
                  "content": "بُنِيَ الإسلامُ على خمسٍ: شهادةِ أن لا إلهَ إلا اللهُ وأنَّ محمداً رسولُ الله، وإقامِ الصلاةِ، وإيتاءِ الزكاةِ، وحجِّ البيتِ، وصومِ رمضانَ",
                  "order": 4,
                  "conceptRef": "concept_isl_arkaan",
                  "caption": "حديث ابن عمر — متفق عليه",
                  "metadata": null
                },
                {
                  "id": "blk_isl_heading2",
                  "type": "HEADING",
                  "content": "أركان الإسلام الخمسة",
                  "order": 5,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_isl_list1",
                  "type": "LIST",
                  "content": "الشهادتان: شهادة أن لا إله إلا الله وأن محمداً رسول الله\nالصلاة: خمس صلوات في اليوم والليلة\nالزكاة: إخراج حق واجب من المال لمستحقيه\nصوم رمضان: الإمساك عن المفطرات من الفجر إلى الغروب\nالحج: قصد بيت الله الحرام لأداء مناسك مخصوصة مرة في العمر",
                  "order": 6,
                  "conceptRef": "concept_isl_arkaan",
                  "caption": "أركان الإسلام الخمسة",
                  "metadata": "{\"style\": \"numbered\"}"
                },
                {
                  "id": "blk_isl_divider1",
                  "type": "DIVIDER",
                  "content": "",
                  "order": 7,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_isl_heading3",
                  "type": "HEADING",
                  "content": "الصلاة وأوقاتها",
                  "order": 8,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_isl_table1",
                  "type": "TABLE",
                  "content": "{\"headers\":[\"الصلاة\",\"وقتها\",\"عدد الركعات\"],\"rows\":[{\"cells\":[\"الفجر\",\"من طلوع الفجر إلى شروق الشمس\",\"2\"]},{\"cells\":[\"الظهر\",\"من زوال الشمس إلى العصر\",\"4\"]},{\"cells\":[\"العصر\",\"من مصير الظل مثليه إلى الغروب\",\"4\"]},{\"cells\":[\"المغرب\",\"من غروب الشمس إلى اختفاء الشفق\",\"3\"]},{\"cells\":[\"العشاء\",\"من اختفاء الشفق إلى منتصف الليل\",\"4\"]}]}",
                  "order": 9,
                  "conceptRef": "concept_isl_salah",
                  "caption": "الصلوات الخمس وأوقاتها وركعاتها",
                  "metadata": null
                },
                {
                  "id": "blk_isl_example1",
                  "type": "EXAMPLE",
                  "content": "شروط صحة الصلاة:\n• الطهارة من الحدثين الأصغر والأكبر\n• استقبال القبلة\n• ستر العورة\n• دخول وقت الصلاة\n• النية",
                  "order": 10,
                  "conceptRef": "concept_isl_salah",
                  "caption": "شروط صحة الصلاة",
                  "metadata": null
                },
                {
                  "id": "blk_isl_tip1",
                  "type": "TIP",
                  "content": "مساعدة على الحفظ: رتّب الأركان بالترتيب المنطقي — الإيمان (الشهادتان) ثم العبادة (الصلاة، الزكاة) ثم الصيام ثم الحج.",
                  "order": 11,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_isl_formula1",
                  "type": "FORMULA",
                  "content": "نصاب الزكاة = 85 جرام من الذهب\nمقدار الزكاة = 2.5\\% من المال",
                  "order": 12,
                  "conceptRef": "concept_isl_salah",
                  "caption": "نصاب زكاة المال",
                  "metadata": null
                }
              ]
            }
          ]
        }
