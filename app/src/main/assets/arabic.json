  "units": [
    {
      "id": "unit_ar_nahw",
      "title": "النحو والصرف",
      "order": 1,
      "description": "دراسة قواعد اللغة العربية وإعراب الجمل",
      "lessons": [
        {
          "id": "lesson_ar_jumla",
          "title": "الجملة الاسمية وأركانها",
          "order": 1,
          "estimatedMinutes": 20,
          "summary": "دراسة أركان الجملة الاسمية وأحكام المبتدأ والخبر",
          "sections": [
            {
              "id": "sec_ar_mubtada",
              "title": "المبتدأ والخبر",
              "order": 1,
              "partIndex": 0,
              "conceptIds": [
                "concept_ar_mubtada",
                "concept_ar_ithbat"
              ],
              "blocks": [
                {
                  "id": "blk_ar_text1",
                  "type": "TEXT",
                  "content": "اللغة العربية من أغنى لغات العالم وأقدمها، وقد احتفظت بكثير من خصائصها وأساليبها عبر القرون. والنحو العربي هو العمود الفقري لفهم النصوص وتركيب الجمل، إذ يضع القواعد التي تحكم بنية الكلام وصحة التعبير.",
                  "order": 1,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_ar_heading1",
                  "type": "HEADING",
                  "content": "أركان الجملة الاسمية",
                  "order": 2,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_ar_highlight1",
                  "type": "HIGHLIGHT_BOX",
                  "content": "الجملة الاسمية: جملة تبدأ باسم وتتكون من ركنين أساسيين:\n• المبتدأ: اسم مرفوع يُبنى عليه الكلام\n• الخبر: اسم أو جملة مرفوعة تكمل المعنى\nمثال: العِلمُ نورٌ",
                  "order": 3,
                  "conceptRef": "concept_ar_ithbat",
                  "caption": null,
                  "metadata": "{\"style\": \"definition\"}"
                },
                {
                  "id": "blk_ar_example1",
                  "type": "EXAMPLE",
                  "content": "أمثلة على الجملة الاسمية:\n• «المجتهدُ ناجحٌ» — المبتدأ: المجتهدُ / الخبر: ناجحٌ\n• «الكتابُ مفيدٌ» — المبتدأ: الكتابُ / الخبر: مفيدٌ\n• «السماءُ صافيةٌ» — المبتدأ: السماءُ / الخبر: صافيةٌ",
                  "order": 4,
                  "conceptRef": "concept_ar_mubtada",
                  "caption": "تطبيقات على الجملة الاسمية",
                  "metadata": null
                },
                {
                  "id": "blk_ar_list1",
                  "type": "LIST",
                  "content": "يكون المبتدأ اسماً صريحاً: «الطالبُ مجتهدٌ»\nيكون المبتدأ مصدراً مؤولاً: «أن تجتهدَ واجبٌ»\nيكون المبتدأ ضميراً منفصلاً: «أنتَ مجتهدٌ»",
                  "order": 5,
                  "conceptRef": "concept_ar_mubtada",
                  "caption": "أنواع المبتدأ",
                  "metadata": "{\"style\": \"numbered\"}"
                },
                {
                  "id": "blk_ar_divider1",
                  "type": "DIVIDER",
                  "content": "",
                  "order": 6,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                }
              ]
            },
            {
              "id": "sec_ar_tashabih",
              "title": "التشبيه البلاغي",
              "order": 2,
              "partIndex": 1,
              "conceptIds": [
                "concept_ar_tashabih"
              ],
              "blocks": [
                {
                  "id": "blk_ar_heading2",
                  "type": "HEADING",
                  "content": "التشبيه في البلاغة",
                  "order": 1,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_ar_text2",
                  "type": "TEXT",
                  "content": "التشبيه من أقدم الصور البلاغية وأكثرها شيوعاً في الشعر والنثر العربي. يتكون التشبيه من أربعة أركان: المشبَّه، وأداة التشبيه، ووجه الشبه، والمشبَّه به.",
                  "order": 2,
                  "conceptRef": "concept_ar_tashabih",
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_ar_table1",
                  "type": "TABLE",
                  "content": "{\"headers\":[\"الركن\",\"المعنى\",\"في المثال: العلم كالنور\"],\"rows\":[{\"cells\":[\"المشبَّه\",\"ما نُريد توضيحه\",\"العلم\"]},{\"cells\":[\"أداة التشبيه\",\"ما يدل على المشاركة\",\"كـ\"]},{\"cells\":[\"المشبَّه به\",\"ما قِيس عليه\",\"النور\"]},{\"cells\":[\"وجه الشبه\",\"الصفة المشتركة\",\"الهداية والإضاءة\"]}]}",
                  "order": 3,
                  "conceptRef": "concept_ar_tashabih",
                  "caption": "أركان التشبيه",
                  "metadata": null
                },
                {
                  "id": "blk_ar_quote1",
                  "type": "QUOTE",
                  "content": "أنا البحرُ في أحشائه الدرُّ كامنٌ — فهل سألوا الغوّاصَ عن صَدَفاتي",
                  "order": 4,
                  "conceptRef": "concept_ar_tashabih",
                  "caption": "المتنبي — مثال على التشبيه البليغ",
                  "metadata": null
                },
                {
                  "id": "blk_ar_tip1",
                  "type": "TIP",
                  "content": "لتمييز المبتدأ من الخبر: المبتدأ هو ما نتحدث عنه، والخبر هو ما نقوله عنه. ابحث عن الاسم الأول في الجملة وهو غالباً المبتدأ.",
                  "order": 5,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                }
              ]
            }
          ],
          "metadata": {
            "hook": "لماذا يقول العرب «العِلمُ نورٌ» ولا يقولون «نورٌ العِلمُ»؟ الترتيب في الجملة العربية ليس عشوائياً — وراءه قانون دقيق.",
            "orientation": [
              "تمييز المبتدأ والخبر في أي جملة اسمية",
              "تطبيق قواعد الرفع على أركان الجملة",
              "التعرف على أركان التشبيه البلاغي الأربعة",
              "الفرق بين التشبيه التام والبليغ"
            ],
            "forwardPull": "في الدرس القادم: الفعل وفاعله — كيف تتحول الجملة من اسمية إلى فعلية"
          }
        }
      ]
    }
  ],
