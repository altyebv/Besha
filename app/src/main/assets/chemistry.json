      "lessons": [
        {
          "id": "lesson_chem_bonds",
          "title": "الروابط الكيميائية",
          "order": 1,
          "estimatedMinutes": 25,
          "summary": "دراسة أنواع الروابط الكيميائية وخصائصها",
          "sections": [
            {
              "id": "sec_chem_atom",
              "title": "تركيب الذرة",
              "order": 1,
              "conceptIds": [
                "concept_chem_atom",
                "concept_chem_ionic"
              ],
              "blocks": [
                {
                  "id": "blk_chem_text1",
                  "type": "TEXT",
                  "content": "الكيمياء هي علم المادة وتحولاتها. تُشكّل الذرات اللبنات الأساسية لكل ما يحيط بنا، من الهواء الذي نتنفسه إلى الأدوية التي نستخدمها. إن فهم كيفية تفاعل الذرات وارتباطها ببعضها هو جوهر علم الكيمياء.",
                  "order": 1,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_chem_heading1",
                  "type": "HEADING",
                  "content": "مكونات الذرة",
                  "order": 2,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_chem_image1",
                  "type": "IMAGE",
                  "content": "media/images.png",
                  "order": 3,
                  "conceptRef": "concept_chem_atom",
                  "caption": "نموذج مبسط لذرة الهيليوم يُظهر النواة والإلكترونات",
                  "metadata": null
                },
                {
                  "id": "blk_chem_list1",
                  "type": "LIST",
                  "content": "البروتونات: جسيمات موجبة الشحنة توجد في النواة\nالنيوترونات: جسيمات متعادلة توجد في النواة\nالإلكترونات: جسيمات سالبة الشحنة تدور حول النواة في مستويات طاقة",
                  "order": 4,
                  "conceptRef": "concept_chem_atom",
                  "caption": "مكونات الذرة الثلاثة",
                  "metadata": "{\"style\": \"bullet\"}"
                },
                {
                  "id": "blk_chem_formula1",
                  "type": "FORMULA",
                  "content": "A = Z + N",
                  "order": 5,
                  "conceptRef": "concept_chem_atom",
                  "caption": "العدد الكتلي = عدد البروتونات + عدد النيوترونات",
                  "metadata": null
                },
                {
                  "id": "blk_chem_highlight1",
                  "type": "HIGHLIGHT_BOX",
                  "content": "الرابطة الأيونية: تتشكل عندما تنتقل إلكترونات من ذرة (تصبح موجبة - كاتيون) إلى ذرة أخرى (تصبح سالبة - أنيون)، ثم يتجاذب الأيونان كهربائياً.",
                  "order": 6,
                  "conceptRef": "concept_chem_ionic",
                  "caption": null,
                  "metadata": "{\"style\": \"definition\"}"
                },
                {
                  "id": "blk_chem_example1",
                  "type": "EXAMPLE",
                  "content": "تكوين كلوريد الصوديوم (ملح الطعام NaCl):\n• ذرة الصوديوم (Na) تفقد إلكتروناً واحداً → تصبح أيون Na⁺\n• ذرة الكلور (Cl) تكتسب إلكتروناً واحداً → تصبح أيون Cl⁻\n• يتجاذب الأيونان ليكوّنا رابطة أيونية قوية",
                  "order": 7,
                  "conceptRef": "concept_chem_ionic",
                  "caption": "مثال: تكوين ملح الطعام",
                  "metadata": null
                },
                {
                  "id": "blk_chem_formula2",
                  "type": "FORMULA",
                  "content": "\\text{Na} + \\text{Cl} \\rightarrow \\text{Na}^{+} + \\text{Cl}^{-} \\rightarrow \\text{NaCl}",
                  "order": 8,
                  "conceptRef": "concept_chem_ionic",
                  "caption": "تكوين كلوريد الصوديوم بانتقال الإلكترون",
                  "metadata": null
                },
                {
                  "id": "blk_chem_tip1",
                  "type": "TIP",
                  "content": "قاعدة مفيدة: الفلزات تميل لفقد الإلكترونات (تتأين إيجاباً)، بينما اللافلزات تميل لاكتساب الإلكترونات (تتأين سلبياً).",
                  "order": 9,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_chem_divider1",
                  "type": "DIVIDER",
                  "content": "",
                  "order": 10,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_chem_heading2",
                  "type": "HEADING",
                  "content": "التفاعلات الكيميائية",
                  "order": 11,
                  "conceptRef": null,
                  "caption": null,
                  "metadata": "{\"level\": 2}"
                },
                {
                  "id": "blk_chem_text2",
                  "type": "TEXT",
                  "content": "التفاعل الكيميائي هو عملية تتحول فيها المواد الأصلية (المتفاعلات) إلى مواد جديدة (النواتج). خلال هذه العملية تُكسر بعض الروابط القديمة وتُكوَّن روابط جديدة. يُكتب التفاعل في معادلة كيميائية تُظهر المتفاعلات على اليسار والنواتج على اليمين.",
                  "order": 12,
                  "conceptRef": "concept_chem_reaction",
                  "caption": null,
                  "metadata": null
                },
                {
                  "id": "blk_chem_quote1",
                  "type": "QUOTE",
                  "content": "لا تُخلق المادة ولا تُفنى، بل تتحول من شكل إلى آخر.",
                  "order": 13,
                  "conceptRef": null,
                  "caption": "قانون حفظ المادة - لافوازييه",
                  "metadata": null
                }
              ]
            }
          ]
        }
      ]
    }
